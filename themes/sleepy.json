  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8b949e" }
    },
    {
      "scope": ["constant.other.placeholder", "constant.character"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "entity"
      ],
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": [
        "entity.name",
        "meta.export.default",
        "meta.definition.variable"
      ],
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": [
        "variable.parameter.function",
        "meta.jsx.children",
        "meta.block",
        "meta.tag.attributes",
        "entity.name.constant",
        "meta.object.member",
        "meta.embedded.expression"
      ],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": "entity.name.function",
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": "keyword",
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": ["string", "string punctuation.section.embedded source"],
      "settings": { "foreground": "#87d8f7" }
    },
    {
      "scope": "support",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": ["support.type.primitive", "support.type.builtin"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": "meta.property-name",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": "variable.other",
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": ["variable.property", "variable.object.property"],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": [
        "keyword.operator.type",
        "keyword.operator.typecast",
        "keyword.operator.type.function"
      ],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": "invalid.broken",
      "settings": { "fontStyle": "italic", "foreground": "#ffa198" }
    },
    {
      "scope": "invalid.deprecated",
      "settings": { "fontStyle": "italic", "foreground": "#ffa198" }
    },
    {
      "scope": "invalid.illegal",
      "settings": { "fontStyle": "italic", "foreground": "#ffa198" }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": { "fontStyle": "italic", "foreground": "#ffa198" }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "fontStyle": "italic underline",
        "background": "#ff7b72",
        "foreground": "#f0f6fc",
        "content": "^M"
      }
    },
    {
      "scope": "message.error",
      "settings": { "foreground": "#ffa198" }
    },
    {
      "scope": "string variable",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": ["source.regexp", "string.regexp"],
      "settings": { "foreground": "#87d8f7" }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": { "foreground": "#87d8f7" }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": { "fontStyle": "bold", "foreground": "#7ee787" }
    },
    {
      "scope": "support.constant",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": "support.variable",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": "meta.module-reference",
      "settings": { "foreground": "#58C4F5" }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": { "fontStyle": "bold", "foreground": "#58C4F5" }
    },
    {
      "scope": "markup.quote",
