  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8c8fa1" }
    },
    {
      "scope": ["constant.other.placeholder", "constant.character"],
      "settings": { "foreground": "#d20f39" }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language",
        "entity"
      ],
      "settings": { "foreground": "#04a5e5" }
    },
    {
      "scope": [
        "entity.name",
        "meta.export.default",
        "meta.definition.variable"
      ],
      "settings": { "foreground": "#fe640b" }
    },
    {
      "scope": [
        "variable.parameter.function",
        "meta.jsx.children",
        "meta.block",
        "meta.tag.attributes",
        "entity.name.constant",
        "meta.object.member",
        "meta.embedded.expression"
      ],
      "settings": { "foreground": "#4c4f69" }
    },
    {
      "scope": "entity.name.function",
      "settings": { "foreground": "#8839ef" }
    },
    {
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#40a02b" }
    },
    {
      "scope": "keyword",
      "settings": { "foreground": "#d20f39" }
    },
    {
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#d20f39" }
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": { "foreground": "#4c4f69" }
    },
    {
      "scope": ["string", "string punctuation.section.embedded source"],
      "settings": { "foreground": "#209fb5" }
    },
    {
      "scope": "support",
      "settings": { "foreground": "#04a5e5" }
    },
    {
      "scope": ["support.type.primitive", "support.type.builtin"],
      "settings": { "foreground": "#d20f39" }
    },
    {
      "scope": "meta.property-name",
      "settings": { "foreground": "#04a5e5" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#fe640b" }
    },
    {
      "scope": "variable.other",
      "settings": { "foreground": "#4c4f69" }
    },
    {
      "scope": ["variable.property", "variable.object.property"],
      "settings": { "foreground": "#4c4f69" }
    },
    {
      "scope": [
        "keyword.operator.type",
        "keyword.operator.typecast",
        "keyword.operator.type.function"
      ],
      "settings": { "foreground": "#d20f39" }
    },
    {
      "scope": "invalid.broken",
      "settings": { "fontStyle": "italic", "foreground": "#dd7878" }
    },
    {
      "scope": "invalid.deprecated",
      "settings": { "fontStyle": "italic", "foreground": "#dd7878" }
    },
    {
      "scope": "invalid.illegal",
      "settings": { "fontStyle": "italic", "foreground": "#dd7878" }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": { "fontStyle": "italic", "foreground": "#dd7878" }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "fontStyle": "italic underline",
        "background": "#d20f39",
        "foreground": "#4c4f69",
        "content": "^M"
      }
    },
    {
      "scope": "message.error",
      "settings": { "foreground": "#dd7878" }
    },
    {
      "scope": "string variable",
      "settings": { "foreground": "#04a5e5" }
    },
    {
      "scope": ["source.regexp", "string.regexp"],
      "settings": { "foreground": "#209fb5" }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": { "foreground": "#209fb5" }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": { "fontStyle": "bold", "foreground": "#40a02b" }
    },
    {
      "scope": "support.constant",
      "settings": { "foreground": "#04a5e5" }
    },
    {
